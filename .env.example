# Copy to .env.local for dev, or .env.production on the server before `npm run build`.
# Browser-visible API base (no trailing slash). Required for production (e.g. signup against live API).
NEXT_PUBLIC_API_URL=https://api.verifield.com.ng

# Optional: Laravel Reverb (live map). Defaults: host from NEXT_PUBLIC_API_URL, port 8080, no TLS.
# NEXT_PUBLIC_REVERB_APP_KEY=your-reverb-app-key
# NEXT_PUBLIC_REVERB_HOST=api.verifield.com.ng
# NEXT_PUBLIC_REVERB_WS_PORT=443
# NEXT_PUBLIC_REVERB_WSS_PORT=443
# NEXT_PUBLIC_REVERB_FORCE_TLS=true
